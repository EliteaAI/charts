{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Pylon Helm Chart Values",
  "description": "Schema for values.yaml of the Pylon Helm chart",
  "type": "object",
  "properties": {
    "global": {
      "type": "object",
      "properties": {
        "imagePullSecrets": { "type": "array", "items": { "type": "object" } }
      },
      "additionalProperties": true
    },
    "common": {
      "type": "object",
      "description": "Values injected by common chart library",
      "additionalProperties": true
    },
    "enabled": {
      "type": "boolean",
      "default": true,
      "description": "Enable or disable this component"
    },
    "nameOverride": { "type": "string" },
    "fullnameOverride": { "type": "string" },
    "logLevel": {
      "type": "string",
      "enum": ["debug", "info", "warn", "error"],
      "default": "info"
    },
    "image": {
      "type": "object",
      "properties": {
        "repository": { "type": "string" },
        "tag": { "type": "string" },
        "pullPolicy": {
          "type": "string",
          "enum": ["Always", "IfNotPresent", "Never"],
          "default": "IfNotPresent"
        }
      },
      "required": ["repository"],
      "additionalProperties": true
    },
    "replicaCount": {
      "type": "integer",
      "minimum": 0,
      "default": 1
    },
    "strategy": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["RollingUpdate", "Recreate"]
        },
        "rollingUpdate": {
          "type": "object",
          "properties": {
            "maxSurge": { "type": ["integer", "string"] },
            "maxUnavailable": { "type": ["integer", "string"] }
          }
        }
      },
      "additionalProperties": false
    },
    "podSecurityContext": {
      "type": "object",
      "additionalProperties": true
    },
    "securityContext": {
      "type": "object",
      "additionalProperties": true
    },
    "autoscaling": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean", "default": false },
        "minReplicas": { "type": "integer", "minimum": 1 },
        "maxReplicas": { "type": "integer", "minimum": 1 },
        "targetCPUUtilizationPercentage": { "type": "integer", "minimum": 1, "maximum": 100 }
      },
      "additionalProperties": false
    },
    "labels": { "type": "object", "additionalProperties": { "type": "string" } },
    "annotations": { "type": "object", "additionalProperties": { "type": "string" } },
    "podLabels": { "type": "object", "additionalProperties": { "type": "string" } },
    "podAnnotations": { "type": "object", "additionalProperties": { "type": "string" } },
    "service": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean", "default": true },
        "type": {
          "type": "string",
          "enum": ["ClusterIP", "NodePort", "LoadBalancer"],
          "default": "ClusterIP"
        },
        "port": { "type": "integer", "default": 8080 },
        "containerPort": { "type": "integer" },
        "portName": { "type": "string" }
      },
      "additionalProperties": true
    },
    "route": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean", "default": false },
        "gateway": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "namespace": { "type": "string" },
            "sectionName": { "type": "string" }
          },
          "additionalProperties": false
        },
        "hostnames": { "type": "array", "items": { "type": "string" } },
        "pathPrefix": { "type": "string", "default": "/" },
        "annotations": { "type": "object", "additionalProperties": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "livenessProbe": {
      "type": "object",
      "additionalProperties": true
    },
    "readinessProbe": {
      "type": "object",
      "additionalProperties": true
    },
    "resources": {
      "type": "object",
      "properties": {
        "requests": {
          "type": "object",
          "properties": {
            "cpu": { "type": "string" },
            "memory": { "type": "string" }
          }
        },
        "limits": {
          "type": "object",
          "properties": {
            "cpu": { "type": "string" },
            "memory": { "type": "string" }
          }
        }
      },
      "additionalProperties": false
    },
    "storage": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean", "default": true },
        "size": { "type": "string", "default": "10Gi" },
        "mountPath": { "type": "string" },
        "class": { "type": "string" },
        "existingClaim": { "type": "string" },
        "accessMode": { "type": "string" }
      },
      "additionalProperties": false
    },
    "tmpStorage": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean", "default": true },
        "mountPath": { "type": "string" },
        "sizeLimit": { "type": "string" }
      },
      "additionalProperties": false
    },
    "config": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "mountPath": { "type": "string" },
        "files": { "type": "object", "additionalProperties": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "cacerts": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "mountPath": { "type": "string" },
        "existingSecret": { "type": "string" }
      },
      "additionalProperties": false
    },
    "serviceAccount": {
      "type": "object",
      "properties": {
        "create": { "type": "boolean", "default": false },
        "name": { "type": "string" },
        "annotations": { "type": "object", "additionalProperties": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "rbac": {
      "type": "object",
      "properties": {
        "create": { "type": "boolean", "default": true }
      },
      "additionalProperties": false
    },
    "jobs": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean", "default": false }
      },
      "additionalProperties": false
    },
    "nodeSelector": { "type": "object", "additionalProperties": { "type": "string" } },
    "tolerations": { "type": "array", "items": { "type": "object" } },
    "affinity": { "type": "object", "additionalProperties": true },
    "extraVolumes": { "type": "array", "items": { "type": "object" } },
    "extraVolumeMounts": { "type": "array", "items": { "type": "object" } },
    "sidecars": { "type": "array", "items": { "type": "object" } },
    "initContainers": { "type": "array", "items": { "type": "object" } },
    "env": {
      "type": "object",
      "additionalProperties": { "type": "string" },
      "description": "Static environment variables"
    },
    "configData": {
      "type": "object",
      "additionalProperties": { "type": "string" },
      "description": "ConfigMap static data values"
    },
    "configRefs": {
      "type": "object",
      "additionalProperties": {
        "oneOf": [
          { "type": "null" },
          {
            "type": "object",
            "properties": {
              "configMapName": { "type": "string" },
              "key": { "type": "string" }
            },
            "required": ["key"],
            "additionalProperties": false
          }
        ]
      },
      "description": "ConfigMap placeholder keys (null to disable)"
    },
    "secretRefs": {
      "type": "object",
      "additionalProperties": {
        "oneOf": [
          { "type": "null" },
          {
            "type": "object",
            "properties": {
              "secretName": { "type": "string" },
              "key": { "type": "string" }
            },
            "required": ["key"],
            "additionalProperties": false
          }
        ]
      },
      "description": "Secret references for environment variables (null to disable)"
    },
    "imagePullSecrets": { "type": "array", "items": { "type": "object" } },
    "command": { "type": "array", "items": { "type": "string" } },
    "args": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}
